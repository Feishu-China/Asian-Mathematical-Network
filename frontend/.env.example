# Default local UI development:
# Leave VITE_API_BASE_URL unset so the frontend uses Vite's /api/v1 proxy -> http://127.0.0.1:3000
# VITE_API_BASE_URL=

# Real-flow / acceptance:
# Start a dedicated frontend dev server on 5175 and point it directly at the stable backend on 3001.
# VITE_API_BASE_URL="http://127.0.0.1:3001/api/v1"
