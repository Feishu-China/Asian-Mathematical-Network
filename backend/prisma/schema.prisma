generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                     @id @default(uuid())
  email                   String                     @unique
  passwordHash            String
  status                  String                     @default("active") // active, inactive, suspended
  emailVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  profile                 Profile?
  createdConferences      Conference[]               @relation("ConferenceCreator")
  createdGrantOpportunities GrantOpportunity[]       @relation("GrantOpportunityCreator")
  conferenceStaff         ConferenceStaff[]
  userRoles               UserRole[]
  applications            Application[]              @relation("ApplicationApplicant")
  applicationStatusEvents ApplicationStatusHistory[] @relation("ApplicationStatusChangedBy")
  assignedReviewAssignments ReviewAssignment[]       @relation("ReviewAssignmentReviewer")
  createdReviewAssignments ReviewAssignment[]        @relation("ReviewAssignmentAssigner")
  decisions               Decision[]                 @relation("DecisionMaker")
}

model Profile {
  userId               String           @id
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                 String           @unique
  fullName             String
  title                String?
  institutionId        String?
  institutionNameRaw   String?
  countryCode          String?
  careerStage          String?
  bio                  String?
  personalWebsite      String?
  researchKeywordsJson String           @default("[]")
  orcidId              String?
  coiDeclarationText   String           @default("")
  isProfilePublic      Boolean          @default(false)
  verificationStatus   String           @default("unverified")
  verifiedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  mscCodes             ProfileMscCode[]
}

model MscCode {
  code     String           @id
  profiles ProfileMscCode[]
}

model ProfileMscCode {
  userId    String
  mscCode   String
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())
  profile   Profile          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  codeRef   MscCode          @relation(fields: [mscCode], references: [code], onDelete: Restrict)

  @@id([userId, mscCode])
}

model Conference {
  id                        String            @id @default(uuid())
  slug                      String            @unique
  title                     String
  shortName                 String?
  locationText              String?
  startDate                 String?
  endDate                   String?
  description               String?
  applicationDeadline       DateTime?
  status                    String            @default("draft")
  applicationFormSchemaJson String            @default("{\"fields\":[]}")
  settingsJson              String            @default("{}")
  publishedAt               DateTime?
  closedAt                  DateTime?
  createdByUserId           String
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  creator                   User              @relation("ConferenceCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  staff                     ConferenceStaff[]
  linkedGrants              GrantOpportunity[] @relation("GrantOpportunityLinkedConference")
  applications              Application[]

  @@index([status, applicationDeadline])
}

model GrantOpportunity {
  id                        String        @id @default(uuid())
  linkedConferenceId        String
  slug                      String        @unique
  title                     String
  grantType                 String
  description               String?
  eligibilitySummary        String?
  coverageSummary           String?
  applicationDeadline       DateTime?
  status                    String        @default("draft")
  reportRequired            Boolean       @default(false)
  applicationFormSchemaJson String        @default("{\"fields\":[]}")
  settingsJson              String        @default("{}")
  publishedAt               DateTime?
  closedAt                  DateTime?
  createdByUserId           String
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  linkedConference          Conference    @relation("GrantOpportunityLinkedConference", fields: [linkedConferenceId], references: [id], onDelete: Cascade)
  creator                   User          @relation("GrantOpportunityCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  applications              Application[]

  @@index([status, applicationDeadline])
  @@index([linkedConferenceId, status])
}

model ConferenceStaff {
  id           String     @id @default(uuid())
  conferenceId String
  userId       String
  staffRole    String
  createdAt    DateTime   @default(now())
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conferenceId, userId])
}

model Application {
  id                           String                     @id @default(uuid())
  applicationType              String
  sourceModule                 String
  conferenceId                 String?
  grantId                      String?
  linkedConferenceId           String?
  linkedConferenceApplicationId String?
  applicantUserId              String
  status                       String                     @default("draft")
  participationType            String?
  statement                    String?
  abstractTitle                String?
  abstractText                 String?
  interestedInTravelSupport    Boolean                    @default(false)
  travelPlanSummary            String?
  fundingNeedSummary           String?
  extraAnswersJson             String                     @default("{}")
  applicantProfileSnapshotJson String?
  submittedAt                  DateTime?
  decidedAt                    DateTime?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  conference                   Conference?                @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  grant                        GrantOpportunity?          @relation(fields: [grantId], references: [id], onDelete: Cascade)
  applicant                    User                       @relation("ApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  statusHistory                ApplicationStatusHistory[]
  reviewAssignments            ReviewAssignment[]
  decision                     Decision?
  postVisitReport              PostVisitReport?

  @@unique([conferenceId, applicantUserId, applicationType])
  @@unique([grantId, applicantUserId, applicationType])
  @@index([conferenceId, status])
  @@index([grantId, status])
  @@index([linkedConferenceApplicationId])
  @@index([applicantUserId, status])
}

model ApplicationStatusHistory {
  id              String      @id @default(uuid())
  applicationId   String
  fromStatus      String?
  toStatus        String
  changedByUserId String
  reason          String?
  createdAt       DateTime    @default(now())
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedBy       User        @relation("ApplicationStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@index([userId, isPrimary])
}

model ReviewAssignment {
  id               String      @id @default(uuid())
  applicationId    String
  reviewerUserId   String
  assignedByUserId String
  status           String      @default("assigned")
  conflictState    String      @default("clear")
  conflictNote     String?
  dueAt            DateTime?
  assignedAt       DateTime    @default(now())
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer         User        @relation("ReviewAssignmentReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  assignedBy       User        @relation("ReviewAssignmentAssigner", fields: [assignedByUserId], references: [id], onDelete: Cascade)
  review           Review?

  @@index([reviewerUserId, status, dueAt])
  @@index([applicationId, status])
}

model Review {
  id             String           @id @default(uuid())
  assignmentId   String           @unique
  score          Int?
  recommendation String
  comment        String
  submittedAt    DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignment     ReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model Decision {
  id              String      @id @default(uuid())
  applicationId   String      @unique
  decisionKind    String
  finalStatus     String
  releaseStatus   String      @default("unreleased")
  noteInternal    String?
  noteExternal    String?
  decidedByUserId String
  decidedAt       DateTime    @default(now())
  releasedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  decidedBy       User        @relation("DecisionMaker", fields: [decidedByUserId], references: [id], onDelete: Cascade)

  @@index([releaseStatus, decidedAt])
  @@index([finalStatus, decidedAt])
}

model PostVisitReport {
  id                  String      @id @default(uuid())
  applicationId       String      @unique
  status              String      @default("submitted")
  reportNarrative     String
  attendanceConfirmed Boolean     @default(true)
  submittedAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  application         Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
