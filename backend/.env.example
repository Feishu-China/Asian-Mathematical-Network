# Copy this file to backend/.env for backend workspace runtime commands.
# Official local default: one PostgreSQL instance on 127.0.0.1:5432.
# Keep dev and test isolated by database name, not by port.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/asiamath_dev?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/asiamath_test?schema=public"
# Root-level seed and integration scripts do not auto-read backend/.env;
# export DATABASE_URL in the shell before running those commands.
# Local override: if 5432 is unavailable on your machine, update both URLs in
# backend/.env to the real local port (for example 5433) unless you intentionally
# run dev and test on different PostgreSQL instances.
JWT_SECRET="asiamath-example-jwt-secret-change-before-production"
