{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build:backend",
    "watchPatterns": [
      "/backend/**",
      "/packages/shared/**",
      "/package.json",
      "/package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start:backend"
  }
}
