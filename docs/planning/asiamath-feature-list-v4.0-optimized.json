{
  "project": "Asiamath",
  "version": "4.0-Optimized",
  "description": "融合 v2.2 (质量驱动、工程规范) 与 v3.1 (解耦、高并发团队协作) 的终极开发计划",
  "design_principles": [
    "Contract-First - 在开发前先定义前后端契约 (API + Model)",
    "Mock-Driven - UI 开发 100% 依赖 Mock 服务器，与后端实现解耦",
    "Vertical-Slices - 业务特性按垂直切片划分，实现前端、后端原子化隔离",
    "Parallel-Ready - 最大化并行度，消除阻塞依赖",
    "Quality-Driven - 每次新功能开发前必须进行 Smoke Test，交付前保持 Clean State"
  ],
  "working_rules": {
    "agent_harness_discipline": true,
    "one_feature_at_a_time": true,
    "do_not_edit_test_steps_except_by_pm": true,
    "only_mark_passes_true_after_e2e_verification": true,
    "run_smoke_test_before_new_implementation": true,
    "leave_clean_state_before_handoff": true,
    "required_handoff_artifacts": [
      "progress log entry",
      "API/schema note if changed",
      "commit/changelog message",
      "feature list status update"
    ]
  },
  "decoupling_strategy": {
    "core_approach": "Four-layer staggered parallel development",
    "layers": [
      {
        "layer": "Harness & Contract Layer",
        "description": "工程脚手架搭建、API 契约定义与数据模型建立",
        "deliverables": [
          "Sprint contracts & Smoke test checklist",
          "OpenAPI specifications",
          "Database schema & TS Models"
        ],
        "parallel_potential": "100%",
        "timeline": "Week 1"
      },
      {
        "layer": "Mock Layer",
        "description": "Mock 服务搭建，供前端无阻塞开发",
        "deliverables": [
          "Mock API servers",
          "Test data generators"
        ],
        "parallel_potential": "100%",
        "timeline": "Week 2"
      },
      {
        "layer": "Implementation Layer (Decoupled)",
        "description": "前端对 Mock 开发 UI，后端独立实现接口逻辑",
        "deliverables": [
          "Frontend UI Components (Mock-driven)",
          "Backend Services & DB integration"
        ],
        "parallel_potential": "100%",
        "timeline": "Week 3-6"
      },
      {
        "layer": "Integration Layer",
        "description": "真实 API 联调与端到端测试",
        "deliverables": [
          "Real API integration",
          "E2E test passes"
        ],
        "parallel_potential": "60%",
        "timeline": "Week 7-8"
      }
    ]
  },
